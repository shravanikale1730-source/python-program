# Program to store daily expenses in a file and calculate monthly total

# Step 1: Store daily expenses in a file
file = open("expenses.txt", "w")

days = int(input("Enter number of days you want to store expenses: "))

for i in range(1, days + 1):
    amount = float(input(f"Enter expense for Day {i}: "))
    file.write(str(amount) + "\n")

file.close()

# Step 2: Read file and calculate total monthly expense
file = open("expenses.txt", "r")
total = 0

for line in file:
    total += float(line.strip())

file.close()

print("\n--- Monthly Expense Report ---")
print("Total Monthly Expense:", total)
